{
  "schema_version": "1.0",
  "kind": "output_preset",
  "preset_id": "website_h264_mp4_fallback_ladder",
  "preset_name": "MP4 - H.264 Website Fallback Ladder",
  "preset_version_id": "opv_000001_07-06-26_0000",
  "format": "mp4",
  "description": "H.264 MP4 fallback ladder for website background video outputs.",
  "settings": {
    "codec": "libx264",
    "audio": "remove",
    "preset": "slow",
    "profile": "high",
    "pixel_format": "yuv420p",
    "faststart": true,
    "do_not_upscale": true,
    "scale_filter": "lanczos",
    "preserve_color_metadata": true,
    "fallback_color": {
      "primaries": "bt709",
      "transfer": "bt709",
      "colorspace": "bt709",
      "range": "tv"
    },
    "ladder": [
      {"height": 1080, "crf": 16, "suffix": "-{height}.fallback"},
      {"height": 720, "crf": 18, "suffix": "-{height}.fallback"}
    ]
  },
  "metadata": {
    "built_in": true,
    "dev_seed": true
  }
}
